<component view-model="ProductoRow">
  <div class="container" bind-class="claseSeleccion">
    <div class="imagen">
      <img bind-src="producto.imagen" alt="Imagen del producto" />
    </div>
    <div class="info">
      <p class="principal" bind-content="producto.descripcion"></p>
      <p class="secundario" bind-content="entrega"></p>
    </div>
    <div class="precio">
      <p class="precio" bind-content="precio"></p>
    </div>
  </div>
</component>